generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  phone           String?   @unique
  password        String?
  role            String    @default("patient")
  avatar          String?
  address         String?
  city            String?
  authProvider    String    @default("email")
  phoneVerified   DateTime?
  emailVerified   DateTime?
  otpCode         String?
  otpExpiresAt    DateTime?
  linkedPharmacyId String?
  notificationPreferences String @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reviews       Review[]
  searchHistory SearchHistory[]
  favorites     Favorite[]
  orders        Order[]
  notifications Notification[]
  sentMessages  Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([city])
  @@index([linkedPharmacyId])
}

model Pharmacy {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  district    String?
  latitude    Float?
  longitude   Float?
  phone       String
  email       String?
  isGuard     Boolean  @default(false)
  isPartner   Boolean  @default(true)
  openTime    String   @default("08:00")
  closeTime   String   @default("20:00")
  isOpen24h   Boolean  @default(false)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  imageUrl    String?
  description     String?
  services        String   @default("[]")
  paymentMethods  String   @default("[]")
  parkingInfo     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stocks      PharmacyMedication[]
  reviews     Review[]
  orders      Order[]
  favorites   Favorite[]
  stockHistory StockHistory[]
  promotions  Promotion[]

  @@index([city, district])
  @@index([isGuard])
  @@index([isOpen24h])
  @@index([rating])
}

model Medication {
  id              String   @id @default(cuid())
  name            String
  commercialName  String
  activePrinciple String?
  pathology       String?
  category        String?
  description     String?
  dosage          String?
  sideEffects     String?
  needsPrescription Boolean @default(false)
  imageUrl        String?
  form            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stocks         PharmacyMedication[]
  alternatives   MedicationAlternative[] @relation("MedToAlternatives")
  genericOf      MedicationAlternative[] @relation("AlternativeToMed")
  orderItems     OrderItem[]
  stockHistory   StockHistory[]
  promotions     Promotion[]
}

model MedicationAlternative {
  id           String   @id @default(cuid())
  medicationId String
  alternativeId String
  medication   Medication @relation("MedToAlternatives", fields: [medicationId], references: [id])
  alternative  Medication @relation("AlternativeToMed", fields: [alternativeId], references: [id])
}

model PharmacyMedication {
  id             String   @id @default(cuid())
  pharmacyId     String
  medicationId   String
  price          Float
  inStock            Boolean  @default(true)
  quantity           Int      @default(0)
  needsPrescription  Boolean  @default(false)
  expirationDate     DateTime?
  lowStockAlertSent  Boolean  @default(false)
  updatedAt          DateTime @updatedAt

  pharmacy   Pharmacy   @relation(fields: [pharmacyId], references: [id])
  medication Medication @relation(fields: [medicationId], references: [id])

  @@unique([pharmacyId, medicationId])
}

model StockHistory {
  id           String   @id @default(cuid())
  pharmacyId   String
  medicationId String
  type         String
  quantity     Int
  note         String?
  createdAt    DateTime @default(now())

  pharmacy   Pharmacy   @relation(fields: [pharmacyId], references: [id])
  medication Medication @relation(fields: [medicationId], references: [id])
}

model Order {
  id               String    @id @default(cuid())
  userId           String
  pharmacyId       String
  status           String    @default("pending")
  totalQuantity    Int       @default(0)
  totalPrice       Float     @default(0)
  note             String?
  verificationCode String?   @unique
  verifiedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  pharmacy   Pharmacy   @relation(fields: [pharmacyId], references: [id])
  items      OrderItem[]

  @@index([userId])
  @@index([pharmacyId])
  @@index([status])
  @@index([createdAt])
  @@index([verificationCode])
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  medicationId     String
  quantity         Int
  price            Float
  stockId          String?
  createdAt        DateTime @default(now())

  order       Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  medication Medication @relation(fields: [medicationId], references: [id])

  @@index([orderId])
  @@index([medicationId])
}

model Review {
  id         String    @id @default(cuid())
  userId     String
  pharmacyId String
  rating     Int
  comment    String?
  reply      String?
  replyAt    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])
}

model SearchHistory {
  id         String   @id @default(cuid())
  userId     String
  query      String
  searchType String   @default("medication")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  pharmacyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])

  @@unique([userId, pharmacyId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([createdAt])
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  receiverId String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Promotion {
  id           String   @id @default(cuid())
  pharmacyId   String
  medicationId String?
  name         String
  description  String?
  discountType String   @default("percentage")
  discountValue Float
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  pharmacy   Pharmacy   @relation(fields: [pharmacyId], references: [id])
  medication Medication? @relation(fields: [medicationId], references: [id])

  @@index([pharmacyId, isActive])
  @@index([startDate, endDate])
}
