```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.venv/
venv/
.env
.env.local

# Compiled and binary files
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out
*.class

# OS generated files
.DS_Store
Thumbs.db

# Testing
.mypy_cache/
.pytest_cache/
.nyc_output/
coverage/

# Distribution / packaging
*.tar.gz
*.whl
*.egg-info/
```